# meetbowl-be local environment example
#
# Copy this file to .env for local reference, or register the same values in
# your IDE run configuration / shell environment before running Spring Boot.
# Do not commit a real .env file.

# Spring profile
SPRING_PROFILES_ACTIVE=local

# MariaDB
MEETBOWL_DB_URL=jdbc:mariadb://localhost:3306/meetbowl
MEETBOWL_DB_USERNAME=meetbowl
MEETBOWL_DB_PASSWORD=local-meetbowl-password

# JWT
# Use a long random secret in real environments.
MEETBOWL_JWT_SECRET=change-me-to-a-secure-256-bit-secret

# RabbitMQ
MEETBOWL_RABBITMQ_HOST=localhost
MEETBOWL_RABBITMQ_PORT=5672
MEETBOWL_RABBITMQ_USERNAME=meetbowl
MEETBOWL_RABBITMQ_PASSWORD=local-rabbitmq-password
MEETBOWL_RABBITMQ_VHOST=/
MEETBOWL_RABBITMQ_EXCHANGE=meetbowl.topic

MEETBOWL_ACCESS_TOKEN_EXPIRATION_SECONDS=3600
MEETBOWL_REFRESH_TOKEN_EXPIRATION_SECONDS=1209600
# Required for internal server-to-server APIs. Use the same value in meetbowl-stt.
MEETBOWL_INTERNAL_TOKEN=meetbowl-local-internal-token-32bytes
# Optional override when STT만 별도 토큰을 쓰는 환경이 필요할 때만 설정한다.
# MEETBOWL_STT_INTERNAL_TOKEN=

# LiveKit
# meetbowl-be는 회의 입장 시 room/token 발급만 담당하고, 실제 접속 URL과 서명용 key/secret은 infra와 맞춰야 한다.
MEETBOWL_LIVEKIT_URL=http://localhost:7880
MEETBOWL_LIVEKIT_API_KEY=devkey
MEETBOWL_LIVEKIT_API_SECRET=local-livekit-secret-change-me-123456
MEETBOWL_LIVEKIT_TOKEN_EXPIRATION_SECONDS=3600

# Redis
MEETBOWL_REDIS_HOST=localhost
MEETBOWL_REDIS_PORT=6379

# STT internal API
MEETBOWL_STT_BASE_URL=http://localhost:3000/api/v1

# Mail retention scheduler
# Limits how many mailbox entries are updated per query while applying auto deletion.
MEETBOWL_MAIL_RETENTION_BATCH_SIZE=500
