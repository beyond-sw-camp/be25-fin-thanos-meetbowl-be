# meetbowl-be local environment example
#
# Copy this file to .env for local reference, or register the same values in
# your IDE run configuration / shell environment before running Spring Boot.
# Do not commit a real .env file.

# Spring profile
SPRING_PROFILES_ACTIVE=local

# MariaDB
MEETBOWL_DB_URL=jdbc:mariadb://localhost:3309/meetbowl
MEETBOWL_DB_USERNAME=meetbowl
MEETBOWL_DB_PASSWORD=thanos123

# JWT
# Use a long random secret in real environments.
MEETBOWL_JWT_SECRET=change-me-to-a-secure-256-bit-secret
MEETBOWL_ACCESS_TOKEN_EXPIRATION_SECONDS=900
MEETBOWL_REFRESH_TOKEN_EXPIRATION_SECONDS=1209600

# Redis
MEETBOWL_REDIS_HOST=localhost
MEETBOWL_REDIS_PORT=6379
