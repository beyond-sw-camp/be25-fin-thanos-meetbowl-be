        "fields": {
          "raw": {
            "type": "keyword",
            "normalizer": "user_search_keyword_normalizer"
          }
        }
      },
      "departmentId": {
        "type": "keyword"
      },
      "departmentName": {
        "type": "text",
        "analyzer": "user_search_index_analyzer",
        "search_analyzer": "user_search_query_analyzer",
        "fields": {
          "raw": {
            "type": "keyword",
            "normalizer": "user_search_keyword_normalizer"
          }
        }
      },
      "teamId": {
        "type": "keyword"
      },
      "teamName": {
        "type": "text",
        "analyzer": "user_search_index_analyzer",
        "search_analyzer": "user_search_query_analyzer",
        "fields": {
          "raw": {
            "type": "keyword",
            "normalizer": "user_search_keyword_normalizer"
          }
